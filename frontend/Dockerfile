FROM node:24-alpine AS build

WORKDIR /app

COPY package*.json ./

RUN npm ci

COPY . .

ARG VITE_API_URL
ARG VITE_SOCKET_URL
ARG VITE_CLERK_PUBLISHABLE_KEY
ARG CLERK_SECRET_KEY
ARG CLERK_SIGN_IN_FORCE_REDIRECT_URL
ARG CLERK_SIGN_OUT_FORCE_REDIRECT_URL

ENV VITE_API_URL=${VITE_API_URL}
ENV VITE_SOCKET_URL=${VITE_SOCKET_URL}
ENV VITE_CLERK_PUBLISHABLE_KEY=${VITE_CLERK_PUBLISHABLE_KEY}
ENV CLERK_SECRET_KEY=${CLERK_SECRET_KEY}
ENV CLERK_SIGN_IN_FORCE_REDIRECT_URL=${CLERK_SIGN_IN_FORCE_REDIRECT_URL}
ENV CLERK_SIGN_OUT_FORCE_REDIRECT_URL=${CLERK_SIGN_OUT_FORCE_REDIRECT_URL}

RUN npm run build

FROM node:24-alpine

WORKDIR /app

COPY --from=build /app/dist ./dist
COPY --from=build /app/package*.json ./

EXPOSE 8080

CMD ["node", "dist/server/server.js"]